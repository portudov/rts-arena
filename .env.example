# ─────────── Domaines (Coolify / Traefik) ───────────
CLIENT_URL=https://play.mondomaine.fr
GAME_WS_URL=wss://game.mondomaine.fr            # Traefik -> conteneur server:2567 (TLS terminé sur 443)

# ─────────── Serveur Colyseus (autorité) ───────────
PORT=2567
NODE_ENV=production
# Vérification du JWT Supabase côté serveur (autorité). HS256.
SUPABASE_URL=https://supabase.mondomaine.fr
SUPABASE_JWT_SECRET=__GoTrue_JWT_secret_HS256__
# Écrit le résultat en fin de partie. JAMAIS exposé au client.
SUPABASE_SERVICE_ROLE_KEY=__server_side_only__

# ─────────── Client Next.js (NEXT_PUBLIC_* = injectées au BUILD) ───────────
NEXT_PUBLIC_COLYSEUS_URL=wss://game.mondomaine.fr
NEXT_PUBLIC_SUPABASE_URL=https://supabase.mondomaine.fr
NEXT_PUBLIC_SUPABASE_ANON_KEY=__anon_key__

# ─────────── Dev local (docker-compose / pnpm dev) ───────────
# NEXT_PUBLIC_COLYSEUS_URL=ws://localhost:2567
# NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=__local_anon_key__
