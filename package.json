{
  "name": "rts-arena",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build:shared": "pnpm --filter @rts/shared build",
    "build": "pnpm -r build",
    "dev:server": "pnpm --filter @rts/server dev",
    "dev:client": "pnpm --filter @rts/client dev",
    "dev": "pnpm build:shared && concurrently -n server,client -c green,cyan \"pnpm dev:server\" \"pnpm dev:client\"",
    "lint": "pnpm -r --if-present lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "msgpackr-extract"]
  }
}
